# ======================================================================
# hCaptcha Solver API — environment
# Copy to deploy/.env and fill in. NEVER commit the real .env.
# ======================================================================

# ----------------------------------------------------------------------
# 1) LLM provider (required) — used by AgentV to solve challenges.
#    Pick ONE provider and set its key. See docs/README.md for all options.
# ----------------------------------------------------------------------
# gemini (default) | groq | openai | aikit
LLM_PROVIDER=gemini

# Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
# GEMINI_BASE_URL=            # optional proxy/gateway

# Groq (https://console.groq.com)
# Accepts multiple keys, comma-separated, to rotate/spread load: gsk_a,gsk_b,gsk_c
# GROQ_API_KEY=

# OpenAI-compatible (e.g. Qwen-VL)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen-vl-max

# Qwen via aikit.club
# Accepts multiple tokens, comma-separated, rotated round-robin with per-token refresh.
# AIKIT_API_KEY=

# ----------------------------------------------------------------------
# 2) API security (required) — set at least one API key.
# ----------------------------------------------------------------------
# Comma-separated. Clients send 'Authorization: Bearer <key>' or 'X-API-Key: <key>'.
HCAPTCHA_API_API_KEYS=change-me-please
# Set to false to run WITHOUT auth (not recommended).
HCAPTCHA_API_REQUIRE_AUTH=true
# Per-identity requests/minute (0 = unlimited). In-process (per container).
HCAPTCHA_API_RATE_LIMIT_RPM=120
# Allowed CORS origins (comma-separated). Empty = none.
HCAPTCHA_API_CORS_ORIGINS=
# Expose interactive docs at /docs (disable in prod if unused).
HCAPTCHA_API_ENABLE_DOCS=true

# ----------------------------------------------------------------------
# 3) Capacity / queue — TUNE TO YOUR MACHINE.
#    Defaults below target Linux, 4 GB RAM, 2 CPU. Each concurrent solve
#    is one Chromium context (~300-500 MB). See deploy/README.md.
# ----------------------------------------------------------------------
HCAPTCHA_API_MAX_CONCURRENT_SOLVES=2
HCAPTCHA_API_MAX_QUEUE=32
HCAPTCHA_API_QUEUE_WAIT_TIMEOUT_S=120
HCAPTCHA_API_SOLVE_TIMEOUT_S=180
HCAPTCHA_API_NAV_TIMEOUT_S=60

# ----------------------------------------------------------------------
# 4) Network / misc
# ----------------------------------------------------------------------
HCAPTCHA_API_HOST=0.0.0.0
HCAPTCHA_API_PORT=8000
HCAPTCHA_API_HEADLESS=true
HCAPTCHA_API_LOG_LEVEL=info
