# ======================================================================
# hCaptcha Solver API — environment
# Copy to deploy/.env and fill in. NEVER commit the real .env.
# ======================================================================

# ----------------------------------------------------------------------
# 1) LLM provider (required) — used by AgentV to solve challenges.
#    Pick ONE provider and set its key. See docs/README.md for all options.
# ----------------------------------------------------------------------
# gemini (default) | groq | openai | aikit
# Accuracy note: Gemini is by far the strongest at the coordinate/grid tasks.
# groq (llama-4-scout) and qwen/aikit are notably weaker. For best solve rates
# use gemini. Weaker backends sample at a low temperature (0.1) for stable,
# repeatable coordinates.
LLM_PROVIDER=gemini

# Gemini (https://aistudio.google.com/app/apikey)
# Accepts MULTIPLE keys, comma-separated, rotated round-robin with 429/quota
# failover so one key doesn't throttle the whole service: KEY_A,KEY_B,KEY_C
GEMINI_API_KEY=
# GEMINI_BASE_URL=            # optional proxy/gateway
# Optional accuracy-ordered model fallback chain — great for the FREE tier where
# some models throttle fast. Provider tries each in order, rotating keys first and
# dropping to the next model on rate-limit/unavailable. Unknown ids are skipped.
# GEMINI_MODELS=gemini-3.5-flash,gemini-3-flash,gemini-2.5-flash,gemini-3.1-flash-lite,gemini-2.5-flash-lite,gemma-4-31b-it

# Groq (https://console.groq.com)
# Accepts multiple keys, comma-separated, to rotate/spread load: gsk_a,gsk_b,gsk_c
# GROQ_API_KEY=

# OpenAI-compatible (e.g. Qwen-VL)
# Accepts multiple keys, comma-separated, rotated round-robin with 429 failover: k1,k2,k3
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# OPENAI_MODEL=qwen-vl-max

# Qwen via aikit.club (model defaults to qwen3-vl-plus)
# Accepts multiple tokens, comma-separated, rotated round-robin with per-token refresh.
# Screenshots are uploaded to a temp host so aikit can fetch them by URL, then deleted.
# AIKIT_API_KEY=
# AIKIT_UPLOAD_BASE_URL=https://tmp.malvryx.dev
# AIKIT_UPLOAD_API_KEY=          # optional X-API-Key for higher upload limits
# AIKIT_UPLOAD_EXPIRY=1h
# AIKIT_IMAGE_UPLOAD=true        # set false to disable uploading

# ----------------------------------------------------------------------
# 2) API security (required) — set at least one API key.
# ----------------------------------------------------------------------
# Comma-separated. Clients send 'Authorization: Bearer <key>' or 'X-API-Key: <key>'.
HCAPTCHA_API_API_KEYS=change-me-please
# Set to false to run WITHOUT auth (not recommended).
HCAPTCHA_API_REQUIRE_AUTH=true
# Per-identity requests/minute (0 = unlimited). In-process (per container).
HCAPTCHA_API_RATE_LIMIT_RPM=120
# Allowed CORS origins (comma-separated). Empty = none.
HCAPTCHA_API_CORS_ORIGINS=
# Expose interactive docs at /docs (disable in prod if unused).
HCAPTCHA_API_ENABLE_DOCS=true

# ----------------------------------------------------------------------
# 3) Capacity / queue — TUNE TO YOUR MACHINE.
#    Defaults below target Linux, 4 GB RAM, 2 CPU. Each concurrent solve
#    is one Chromium context (~300-500 MB). See deploy/README.md.
# ----------------------------------------------------------------------
HCAPTCHA_API_MAX_CONCURRENT_SOLVES=2
HCAPTCHA_API_MAX_QUEUE=32
HCAPTCHA_API_QUEUE_WAIT_TIMEOUT_S=120
HCAPTCHA_API_SOLVE_TIMEOUT_S=180
HCAPTCHA_API_NAV_TIMEOUT_S=60
# Max retry rounds per solve when a submission fails. Bounds total solve time so the
# response returns before an upstream proxy (e.g. Cloudflare's ~100s edge) 524s, and
# stops an unbounded retry loop from growing memory. 0 = single attempt.
MAX_RETRY_ON_FAILURE=5

# ----------------------------------------------------------------------
# 4) Network / misc
# ----------------------------------------------------------------------
HCAPTCHA_API_HOST=0.0.0.0
HCAPTCHA_API_PORT=8000
HCAPTCHA_API_HEADLESS=true
HCAPTCHA_API_LOG_LEVEL=info

# ----------------------------------------------------------------------
# 5) Debug live stream (optional) — watch the browser solve in real time.
#    When enabled, a continuous MJPEG video stream is served on STREAM_PORT.
#    It shows "No Task" immediately and switches to the live page when a solve
#    starts, WITHOUT the stream breaking — so you can join first, then send a
#    request. Open in VLC (Open Network Stream) or a browser:
#        http://<host>:8089/             (viewer page)
#        http://<host>:8089/stream.mjpeg (raw MJPEG for VLC)
#    NOTE: this FORCES concurrency to 1 (one task can be streamed). Use behind a
#    private network (e.g. Tailscale) — the stream port is unauthenticated.
# ----------------------------------------------------------------------
HCAPTCHA_API_STREAM_ENABLED=false
HCAPTCHA_API_STREAM_PORT=8089
HCAPTCHA_API_STREAM_FPS=6
HCAPTCHA_API_STREAM_QUALITY=60
HCAPTCHA_API_STREAM_MAX_WIDTH=1280
